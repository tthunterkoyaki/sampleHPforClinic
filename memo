def _st(cfg): return sum(cfg['securities'].values())
def _alt(cfg): return cfg['securities'].get('オルタナティブ',0)
def _trad(cfg): return {k:v for k,v in cfg['securities'].items() if k!='オルタナティブ'}
def analyze_liquidity(cfg):
    bs=cfg['bs']; sec=cfg['securities']
    sr,s={},{}
    sr['現預金・日銀預け金']=bs['cash_deposits']; s['現預金・日銀預け金']=bs['cash_deposits']
    for nm,amt in sec.items(): hc=HC.get(nm,.5); sr[nm]=amt; s[nm]=amt*(1-hc)
    ts=sum(s.values())
    u={}; sm=cfg['stress'].get('stress_months',6)
    u['預金流出（ストレス時）']=bs['deposits']*bs['deposit_outflow_stress_monthly']*sm
    u['キャピタルコール（未消化）']=bs['uncommitted_calls']*cfg['stress'].get('capital_call_rate',.3)
    u['借入金償還']=bs['borrowings']*(sm/12)*.3
    u['クレジットライン実行']=bs.get('credit_line_undrawn',0)*.5
    u['デリバティブ証拠金']=bs.get('derivative_margin_buffer',0)
    tu=sum(u.values()); surplus=ts-tu
    td=_trad(cfg); tt=sum(td.values())
    eff=sum(td[k]*(1-HC.get(k,.5)) for k in td)/tt if tt>0 else .5
    add=max(0,surplus/eff) if eff>0 else 0
    st_=_st(cfg); mx=min((_alt(cfg)+add)/st_,1) if st_>0 else 0
    return {'sources_raw':sr,'sources':s,'uses':u,'total_sources':ts,'total_uses':tu,
            'surplus':surplus,'additional_capacity':add,'max_illiquid_pct':mx}
def calc_lcr_nsfr(cfg, pcts):
    bs=cfg['bs']; sec=cfg['securities']; st_=_st(cfg); td=_trad(cfg); tt=sum(td.values())
    ws_r=bs.get('deposit_wholesale_ratio',0.35); ue=bs.get('securities_unencumbered_ratio',0.60)
    rows=[]
    for p in pcts:
        ill=st_*p; scale=max(0,(st_-ill)/tt) if tt>0 else 0
        cash=bs['cash_deposits']
        jgb=sec.get('国内債券',0)*scale*ue
        fg_h=sec.get('外国債券（H有）',0)*scale*0.85*ue
        hqla_l1=cash+jgb; hqla_l2a=min(fg_h, hqla_l1*0.4/0.6)
        hqla=hqla_l1+hqla_l2a
        dep=bs['deposits']
        out_retail=dep*(1-ws_r)*0.05; out_ws=dep*ws_r*0.40
        out_borr=bs['borrowings']*0.25; out_other=bs.get('derivative_margin_buffer',0)+bs.get('credit_line_undrawn',0)*0.10
        outflows=out_retail+out_ws+out_borr+out_other
        inflows=min(outflows*0.50, st_*0.005)
        net_out=max(outflows-inflows,1)
        lcr=hqla/net_out*100
        asf=bs['tier1_capital']+dep*(1-ws_r)*0.90+dep*ws_r*0.50+bs['borrowings']*0.50
        loan_est=max(0,bs['total_assets']-st_-bs['cash_deposits'])
        rsf=(sec.get('国内債券',0)*scale*0.05+
             (sec.get('外国債券（H有）',0)+sec.get('外国債券（H無）',0))*scale*0.15+
             (sec.get('国内株式',0)+sec.get('外国株式',0))*scale*0.50+
             sec.get('J-REIT',0)*scale*0.50+sec.get('その他（投信等）',0)*scale*0.50+
             ill*0.85+loan_est*0.65+1)
        nsfr=asf/rsf*100
        rows.append({'pct':p,'lcr':lcr,'nsfr':nsfr})
    return pd.DataFrame(rows)
def find_lcr_nsfr_limits(lcr_nsfr_df, lcr_min, nsfr_min):
    cl=lcr_nsfr_df[lcr_nsfr_df['lcr']>=lcr_min*100]
    nl=lcr_nsfr_df[lcr_nsfr_df['nsfr']>=nsfr_min*100]
    return (cl['pct'].max() if not cl.empty else 0), (nl['pct'].max() if not nl.empty else 0)
def simulate_denominator(cfg, pr):
    td=_trad(cfg); stress=cfg['stress']; st_=_st(cfg); tt=sum(td.values())
    rows=[]
    for p in pr:
        ill=st_*p; ta=st_-ill
        s_t=sum((b*(ta/tt) if tt>0 else 0)*(1+stress.get(n,0)) for n,b in td.items())
        s_tot=s_t+ill; pp=ill/s_tot if s_tot>0 else 0
        rows.append({'initial_pct':p,'post_stress_pct':pp,'amplification':pp/p if p>0 else 1})
    return pd.DataFrame(rows)
def check_regulatory(cfg, pr):
    bs=cfg['bs']; reg=cfg['regulation']; st_=_st(cfg); cur=_alt(cfg)
    avg_rwa=cfg['alt_categories']['RWAウェイト'].mean()
    nf=reg.get('funds_per_category',3)*len(cfg['alt_categories'])
    rows=[]
    for p in pr:
        ill=st_*p; delta=ill-cur; rwa=bs['existing_rwa']+delta*(avg_rwa-0.5)
        cr=bs['tier1_capital']/rwa if rwa>0 else 0
        ms=ill/nf if nf>0 else ill; se=ms/bs['tier1_capital'] if bs['tier1_capital']>0 else 0
        rows.append({'pct':p,'rwa':rwa,'rwa_ok':rwa<=reg['rwa_limit'],
                     'cap_ratio':cr,'cap_ok':cr>=reg['capital_ratio_min'],
                     'single_exp':se,'exp_ok':se<=reg['single_exposure_limit_ratio']})
    return pd.DataFrame(rows)
def derive_cap(liq,den,reg,cfg,lcr_nsfr_df):
    an=cfg['analysis']; reg_p=cfg['regulation']; st_=_st(cfg)
    cl=liq['max_illiquid_pct']
    ps_lim=reg_p.get('post_stress_illiquid_limit',0.30)
    safe=den[den['post_stress_pct']<=ps_lim]
    cd=safe['initial_pct'].max() if not safe.empty else 0
    caps={'流動性バジェット':cl,'デノミネーター効果':cd}
    for chk,lb in [('rwa_ok','RWA'),('cap_ok','自己資本比率'),('exp_ok','大口集中度')]:
        f=reg[~reg[chk]]; caps[f'規制（{lb}）']=f['pct'].min() if not f.empty else 1.0
    lcr_l,nsfr_l=find_lcr_nsfr_limits(lcr_nsfr_df,reg_p.get('lcr_min',1.20),reg_p.get('nsfr_min',1.05))
    caps['LCR']=lcr_l; caps['NSFR']=nsfr_l
    safety=min(caps.values()); practical=max(0,safety-an['safety_buffer_pct'])
    target=safety*an['deployment_rate']; current=_alt(cfg)/st_ if st_>0 else 0
    return {'safety_line':safety,'practical_limit':practical,'target_center':target,
            'current':current,'bottleneck':min(caps,key=caps.get),'detail':caps}
