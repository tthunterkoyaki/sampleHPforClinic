def calc_alm_metrics(W, df, reinvest_target="同一年限", custom_weights=None, reinvest_ratio=1.0):
    m_vals = df['Market_Value'].values
    durations = df['Duration'].values
    base_asset_duration = np.average(durations, weights=m_vals) if np.sum(m_vals) > 0 else 0
    def is_liquid(d): return 1.0 if d <= 3.0 else 0.0
    
    base_liquid_flags = np.array([is_liquid(d) for d in durations])
    base_liquid_ratio = (np.sum(m_vals * base_liquid_flags) / np.sum(m_vals)) * 100.0 if np.sum(m_vals) > 0 else 0
    
    stay_m_vals = m_vals * (1 - W)
    reinvest_m_vals = m_vals * W * reinvest_ratio
    cash_m_vals = m_vals * W * (1 - reinvest_ratio)
    
    if reinvest_target == "同一年限":
        reinvest_dur_sum = np.sum(reinvest_m_vals * durations)
        reinvest_liquid_amt = np.sum(reinvest_m_vals * base_liquid_flags)
    else:
        reinvest_dur_sum = 0.0
        reinvest_liquid_amt = 0.0
        tot_reinvest_val = np.sum(reinvest_m_vals)
        for b_name, weight in custom_weights.items():
            if weight <= 0: continue
            d = get_bucket_d_proxy(b_name)
            amt = tot_reinvest_val * weight
            reinvest_dur_sum += amt * d
            reinvest_liquid_amt += amt * is_liquid(d)
            
    stay_dur_sum = np.sum(stay_m_vals * durations)
    stay_liquid_amt = np.sum(stay_m_vals * base_liquid_flags)
    cash_liquid_amt = np.sum(cash_m_vals)
    
    total_new_m_val = np.sum(stay_m_vals) + np.sum(reinvest_m_vals) + np.sum(cash_m_vals)
    
    if total_new_m_val > 0:
        new_asset_duration = (stay_dur_sum + reinvest_dur_sum) / total_new_m_val
        new_liquid_ratio = ((stay_liquid_amt + reinvest_liquid_amt + cash_liquid_amt) / total_new_m_val) * 100.0
    else:
        new_asset_duration = base_asset_duration
        new_liquid_ratio = base_liquid_ratio
        
    return {'base_dur': base_asset_duration, 'new_dur': new_asset_duration, 'base_liq': base_liquid_ratio, 'new_liq': new_liquid_ratio}
