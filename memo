def calc_nii_paths_vectorized(W, df, S_names, YS_tensor, base_cost, deposit_beta, short_bucket_YS, cash_base_rate, updated_yields, include_t0=False, reinvest_target="同一年限", custom_weights=None, reinvest_ratio=1.0):
    S = len(S_names); N = len(df)
    tot_book = df['Book_Value'].sum()
    coupons = df['Coupon'].values
    durations = df['Duration'].values
    b_vals = df['Book_Value'].values
    m_vals = df['Market_Value'].values
    RY = df['Current_Yield'].values[None, None, :] + YS_tensor
    stay_yield = np.zeros((S, 5, N))
    
    for t in range(5):
        for i, d in enumerate(durations):
            m_cycles_stay = int(t // max(1.0, d))
            if m_cycles_stay == 0:
                stay_yield[:, t, i] = coupons[i]
            else:
                m_time = min(int(m_cycles_stay * max(1.0, d)), 4)
                stay_yield[:, t, i] = RY[:, m_time, i]
                
    C_stay_inc = np.sum((1 - W[None, None, :]) * b_vals[None, None, :] * stay_yield / 100.0, axis=2)
    
    cash_yield = cash_base_rate + short_bucket_YS * 1.0
    cash_inc = np.sum(W[None, None, :] * m_vals[None, None, :] * (1.0 - reinvest_ratio), axis=2) * (cash_yield / 100.0)
    
    reinvest_inc = np.zeros((S, 5))
    nii_t0_reinvest = 0.0
    
    if reinvest_target == "同一年限":
        swap_yield = np.zeros((S, 5, N))
        for t in range(5):
            for i, t_d in enumerate(durations):
                m_cycles_swap = int(t // max(1.0, t_d)) if t_d >= 1.0 else t
                if m_cycles_swap == 0 and t_d >= 1.0:
                    swap_yield[:, t, i] = RY[:, 0, i]
                else:
                    m_time = min(int(m_cycles_swap * max(1.0, t_d)) if t_d >= 1.0 else t, 4)
                    swap_yield[:, t, i] = RY[:, m_time, i]
        reinvest_inc = np.sum(W[None, None, :] * m_vals[None, None, :] * reinvest_ratio * swap_yield / 100.0, axis=2)
        nii_t0_reinvest = np.sum(W * m_vals * reinvest_ratio * (df['Current_Yield'].values / 100.0))
    else:
        for b_name, weight in custom_weights.items():
            if weight <= 0: continue
            target_durations, target_RY, t_YS, t_y0 = get_target_properties_for_bucket(b_name, df, S_names, short_bucket_YS, cash_base_rate, updated_yields)
            swap_yield_k = np.zeros((S, 5, N))
            for t in range(5):
                t_d = target_durations[0] 
                m_cycles_swap = int(t // max(1.0, t_d)) if t_d >= 1.0 else t
                if m_cycles_swap == 0 and t_d >= 1.0:
                    swap_yield_k[:, t, :] = target_RY[:, 0, :]
                else:
                    m_time = min(int(m_cycles_swap * max(1.0, t_d)) if t_d >= 1.0 else t, 4)
                    swap_yield_k[:, t, :] = target_RY[:, m_time, :]
            reinvest_inc += np.sum(W[None, None, :] * m_vals[None, None, :] * reinvest_ratio * weight * swap_yield_k / 100.0, axis=2)
            nii_t0_reinvest += np.sum(W * m_vals * reinvest_ratio * weight * (t_y0 / 100.0))
    
    asset_inc = C_stay_inc + reinvest_inc + cash_inc
    liab_cost = tot_book * ((base_cost + deposit_beta * short_bucket_YS) / 100.0)
    nii_paths = asset_inc - liab_cost
    
    nii_t0_asset = np.sum((1 - W) * b_vals * (coupons / 100.0)) + nii_t0_reinvest + np.sum(W * m_vals * (1-reinvest_ratio)) * (cash_yield[0, 0] / 100.0)
    nii_t0_liab = tot_book * (base_cost / 100.0)
    nii_t0 = nii_t0_asset - nii_t0_liab
    
    res = {}
    for s_idx, sc_name in enumerate(S_names):
        p = nii_paths[s_idx, :]
        res[sc_name] = [nii_t0] + p.tolist() if include_t0 else p.tolist()
    return res
