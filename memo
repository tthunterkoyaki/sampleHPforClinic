def calc_irr(cfs):
    if all(x>=0 for x in cfs) or all(x<=0 for x in cfs): return np.nan
    def npv(r): return sum(c/(1+r)**i for i,c in enumerate(cfs))
    try: return brentq(npv,-0.5,5.0)
    except: return np.nan
def sim_cf(cats,pcts,total,cf_profs=None):
    if cf_profs is None: cf_profs=DEFAULT_CF
    ny=10; pc=np.zeros(ny); pd_=np.zeros(ny); pn=np.zeros(ny)
    for cat,pct in zip(cats,pcts):
        cm=total*(pct/100)
        p=cf_profs.get(cat,{'calls':[-.5,-.3,-.1]+[0]*7,'dists':[.02,.04,.06,.08,.1,.15,.2,.25,.3,.2],'nav':[.45,.75,.85,.9,.85,.75,.6,.4,.15,0]})
        pc+=np.array(p['calls'][:ny])*cm; pd_+=np.array(p['dists'][:ny])*cm; pn+=np.array(p['nav'][:ny])*cm
    net=pc+pd_; cum=np.cumsum(net); dd=abs(min(cum)) if min(cum)<0 else 0
    irr_cfs=[0]+list(net); irr_cfs[-1]+=pn[-1]; irr=calc_irr(irr_cfs)
    return pd.DataFrame({'Year':range(1,ny+1),'Call':pc,'Dist':pd_,'Net':net,'Cum':cum,'NAV':pn}),dd,irr
def run_cf_frontier(cats,pats,total):
    rows=[]
    for pat in pats:
        _,dd,irr=sim_cf(cats,pat,total)
        if not np.isnan(irr): rows.append({**{cats[i]:pat[i] for i in range(len(cats))},'max_dd':dd,'irr':irr})
    df=pd.DataFrame(rows)
    if df.empty: return df
    df=df.sort_values('max_dd'); df['frontier']=False; best=-1e9
    for idx in df.index:
        if df.loc[idx,'irr']>best+1e-6: df.at[idx,'frontier']=True; best=df.loc[idx,'irr']
