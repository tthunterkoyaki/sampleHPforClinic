def get_strategy_volumes(df, df_strategies, strategy_name, budget_limit=50.0):
    vols = np.zeros(len(df))
    if strategy_name == "現状維持 (すべて0)": return vols
    
    if strategy_name in DYNAMIC_STRATS:
        elig_df = df[df['Swap_Eligible'] == 1].copy()
        if elig_df.empty: return vols
        if strategy_name == "全銘柄を一律割合で入替 (予算上限)":
            tl = elig_df['Realized_Loss'].sum()
            if tl <= 0: return vols
            ratio = min(1.0, budget_limit / tl)
            for idx in elig_df.index: vols[idx] = df.at[idx, 'Book_Value'] * ratio
        else:
            sorted_df = elig_df.sort_values(by='Duration', ascending=(strategy_name == "短期から優先して入替 (予算上限)"))
            rb = budget_limit
            for idx in sorted_df.index:
                ml = sorted_df.at[idx, 'Realized_Loss']
                bv = sorted_df.at[idx, 'Book_Value']
                if ml <= 0:
                    vols[idx] = bv
                elif rb >= ml:
                    vols[idx] = bv
                    rb -= ml
                else:
                    vols[idx] = bv * (rb / ml)
                    break
        return vols
    
    for b_name in df['Bucket'].unique():
        match = df_strategies[(df_strategies['Strategy_Name'] == strategy_name) & (df_strategies['Bucket'] == b_name)]
        if not match.empty:
            vol = float(match['Swap_Volume'].values[0])
            b_items = df[(df['Bucket'] == b_name) & (df['Swap_Eligible'] == 1)]
            if not b_items.empty and b_items['Book_Value'].sum() > 0:
                ratio = min(1.0, vol / b_items['Book_Value'].sum())
                for idx in b_items.index: vols[idx] = ratio * b_items.at[idx, 'Book_Value']
    return vols
def calc_expected_delta_nii(weights, df, scenarios):
    exp_delta_nii = 0
    for sc_data in scenarios.values():
        exp_delta_nii += sc_data['prob'] * calc_delta_nii(weights, df, sc_data)
    return exp_delta_nii
