def get_sample_excel():
    output = io.BytesIO()
    with pd.ExcelWriter(output, engine='xlsxwriter') as writer:
        np.random.seed(42)
        port_data = []
        for i in range(1, 41):
            dur = round(np.random.uniform(1.0, 14.0), 1)
            is_recent = np.random.rand() < 0.2
            if is_recent:
                coupon = round(np.random.uniform(0.5, 1.5), 2)
                eligible = 0 if np.random.rand() < 0.8 else 1
            else:
                coupon = round(np.random.uniform(0.05, 0.3), 2)
                eligible = 1
            book = round(np.random.uniform(50, 200), -1)
            mkt = round(book * (1.0 - (dur * 0.015)), -1)
            port_data.append({'Item_Name': f'Bond_{i:02d}_{"Recent" if is_recent else "Legacy"}', 'Book_Value': book, 'Market_Value': mkt, 'Coupon': coupon, 'Duration': dur, 'Swap_Eligible': eligible})
        pd.DataFrame(port_data).to_excel(writer, sheet_name='Portfolio', index=False)
        
        pd.DataFrame({
            'Bucket': BUCKET_ORDER,
            'Current_Yield': [0.5, 0.8, 1.3, 1.8, 2.5]
        }).to_excel(writer, sheet_name='Market_Data', index=False)
        
        pd.DataFrame({'Strategy_Name': ['Excelカスタムテスト', 'Excelカスタムテスト'], 'Bucket': ['残存1-3年', '残存10年超'], 'Swap_Volume': [150, 250]}).to_excel(writer, sheet_name='Strategies', index=False)
        
        scens = []
        for sc in SCENARIO_PROBS.keys():
            for d, b_name in zip([2.0, 4.0, 6.0, 8.5, 12.0], BUCKET_ORDER):
                scens.append({'Scenario_Name': sc, 'Bucket': b_name, 'Year1_Shift': get_unified_ys(sc, 0, b_name, d), 'Year2_Shift': get_unified_ys(sc, 1, b_name, d), 'Year3_Shift': get_unified_ys(sc, 2, b_name, d), 'Year4_Shift': get_unified_ys(sc, 3, b_name, d), 'Year5_Shift': get_unified_ys(sc, 4, b_name, d)})
        pd.DataFrame(scens).to_excel(writer, sheet_name='Scenarios', index=False)
    return output.getvalue()
def export_results_excel(paths, strategy_df):
    output = io.BytesIO()
    with pd.ExcelWriter(output, engine='xlsxwriter') as writer:
        strategy_df.to_excel(writer, sheet_name='Optimal_Strategy', index=False)
        res_data = []
        for sc_name, path in paths.items():
            row = {'Scenario': sc_name}
            for t in range(len(path)): row[f'Year {t}'] = path[t]
            row['Total Flow(1-5)'] = sum(path[1:]) if len(path) > 1 else 0.0
            res_data.append(row)
        pd.DataFrame(res_data).to_excel(writer, sheet_name='NII_Paths', index=False)
    return output.getvalue()
