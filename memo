def get_sample_excel():
    output = io.BytesIO()
    with pd.ExcelWriter(output, engine='xlsxwriter') as writer:
        np.random.seed(42)
        port_data = []
        def approx_yield(d_val):
            if d_val < 3: return 0.5
            if d_val < 5: return 0.8
            if d_val < 7: return 1.3
            if d_val < 10: return 1.8
            return 2.5
            
        for i in range(1, 1501):
            dur = round(np.random.uniform(1.0, 14.0), 1)
            is_recent = np.random.rand() < 0.2
            current_y = approx_yield(dur)
            
            if is_recent:
                coupon = max(0.01, round(np.random.uniform(current_y - 0.2, current_y + 0.2), 2))
                eligible = 0 if np.random.rand() < 0.8 else 1
            else:
                coupon = round(np.random.uniform(0.01, 0.3), 2)
                eligible = 1
                
            loss_ratio = max(0.001, (current_y - coupon) * dur / 100.0) 
            book = round(np.random.uniform(1.0, 6.0), 1)
            mkt = max(0.1, round(book * (1.0 - loss_ratio), 1))
            
            port_data.append({'Item_Name': f'Bond_{i:04d}_{"Recent" if is_recent else "Legacy"}', 'Book_Value': book, 'Market_Value': mkt, 'Coupon': coupon, 'Duration': dur, 'Swap_Eligible': eligible})
        pd.DataFrame(port_data).to_excel(writer, sheet_name='Portfolio', index=False)
        
        pd.DataFrame({
            'Bucket': BUCKET_ORDER,
            'Current_Yield': [0.5, 0.8, 1.3, 1.8, 2.5]
