SCENARIO_NAMES = {
    'Base': 'Base (現状維持)', 'Up': '平行シフト上昇', 'Down': '平行シフト下落',
    'Steep': 'スティープ化', 'Flat': 'フラット化', 'ShortUp': '短期金利上昇', 'ShortDown': '短期金利低下'
}
SCENARIO_PROBS = { n: p for n, p in zip(SCENARIO_NAMES.values(), [0.30, 0.20, 0.10, 0.15, 0.10, 0.10, 0.05]) }
BUCKET_ORDER = ['残存1-3年', '残存3-5年', '残存5-7年', '残存7-10年', '残存10年超']
DYNAMIC_STRATS = [
    "全銘柄を一律割合で入替 (予算上限)",
    "長期から優先して入替 (予算上限)",
    "短期から優先して入替 (予算上限)"
]
def get_bucket(d):
    if d < 3.0: return '残存1-3年'
    elif d < 5.0: return '残存3-5年'
    elif d < 7.0: return '残存5-7年'
    elif d < 10.0: return '残存7-10年'
    else: return '残存10年超'
def get_bucket_d_proxy(b):
    if b == '残存1-3年': return 2.0
    if b == '残存3-5年': return 4.0
    if b == '残存5-7年': return 6.0
    if b == '残存7-10年': return 8.5
    return 12.0
def get_unified_ys(sc_name, t, bucket_name, d, df_scenarios=None):
    if df_scenarios is not None and not df_scenarios.empty:
        df_match = df_scenarios[(df_scenarios['Scenario_Name'] == sc_name) & (df_scenarios['Bucket'] == bucket_name)]
        if not df_match.empty:
            try: return float(df_match.iloc[0][f'Year{t+1}_Shift'])
            except: pass
            
    # BCBS 368 JPY Exact Parameters (Annex 2)
    tf_ratio = (t + 1) / 5.0
    E = np.exp(-d / 4.0)
    
    val = 0.0
    if sc_name == SCENARIO_NAMES['Base']: val = 0.0
    elif sc_name == SCENARIO_NAMES['Up']: val = 1.00
    elif sc_name == SCENARIO_NAMES['Down']: val = -1.00
    elif sc_name == SCENARIO_NAMES['Steep']: val = -1.625 * E + 0.90 * (1.0 - E)
    elif sc_name == SCENARIO_NAMES['Flat']: val = 2.00 * E - 0.60 * (1.0 - E)
    elif sc_name == SCENARIO_NAMES['ShortUp']: val = 2.50 * E
    elif sc_name == SCENARIO_NAMES['ShortDown']: val = -2.50 * E
    return round(val * tf_ratio, 4)
def build_ys_tensor(df, S_names, df_scenarios=None):
    S = len(S_names); N = len(df)
    YS = np.zeros((S, 5, N))
    min_d = df['Duration'].min()
    short_b = df.loc[df['Duration'].idxmin(), 'Bucket'] if len(df) > 0 else "N/A"
    short_YS = np.zeros((S, 5))
    for s_idx, sc_name in enumerate(S_names):
        for t in range(5):
            for i, row in df.iterrows():
                YS[s_idx, t, i] = get_unified_ys(sc_name, t, row['Bucket'], row['Duration'], df_scenarios)
            short_YS[s_idx, t] = get_unified_ys(sc_name, t, short_b, min_d, df_scenarios)
    return YS, short_YS
def build_mc_ys_tensor(df, mc_count):
    S = mc_count; N = len(df)
    S_names = [f"MC_{i}" for i in range(S)]
    YS = np.zeros((S, 5, N))
    np.random.seed(42)
    lvls = np.cumsum(np.random.normal(0.0, 0.3, (S, 5)), axis=1)
    slps = np.cumsum(np.random.normal(0.0, 0.15, (S, 5)), axis=1)
    factor = (df['Duration'].values - 2.0) / 8.0
    for t in range(5): YS[:, t, :] = lvls[:, t, None] + slps[:, t, None] * factor[None, :]
    min_idx = df['Duration'].argmin()
    short_YS = YS[:, :, min_idx]
    return S_names, YS, short_YS
