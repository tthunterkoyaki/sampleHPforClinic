def calc_nii_paths_vectorized(W, df, S_names, YS_tensor, base_cost, deposit_beta, short_bucket_YS, include_t0=False):
    S = len(S_names); N = len(df)
    tot_book = df['Book_Value'].sum()
    coupons = df['Coupon'].values
    durations = df['Duration'].values
    b_vals = df['Book_Value'].values
    m_vals = df['Market_Value'].values
    RY = df['Current_Yield'].values[None, None, :] + YS_tensor
    stay_yield = np.zeros((S, 5, N))
    swap_yield = np.zeros((S, 5, N))
    
    for t in range(5):
        for i, d in enumerate(durations):
            m_cycles = int(t // max(1.0, d))
            if m_cycles == 0:
                stay_yield[:, t, i] = coupons[i]
                swap_yield[:, t, i] = RY[:, 0, i]
            else:
                m_time = int(m_cycles * max(1.0, d))
                if m_time > 4: m_time = 4
                stay_yield[:, t, i] = RY[:, m_time, i]
                swap_yield[:, t, i] = RY[:, m_time, i]
    
    C_stay_inc = np.sum((1 - W[None, None, :]) * b_vals[None, None, :] * stay_yield / 100.0, axis=2)
    reinvest_inc = np.sum(W[None, None, :] * m_vals[None, None, :] * swap_yield / 100.0, axis=2)
    asset_inc = C_stay_inc + reinvest_inc
    
    liab_cost = tot_book * ((base_cost + deposit_beta * short_bucket_YS) / 100.0)
    nii_paths = asset_inc - liab_cost
    
    nii_t0_asset = np.sum((1 - W) * b_vals * (coupons / 100.0)) + np.sum(W * m_vals * (df['Current_Yield'].values / 100.0))
    nii_t0_liab = tot_book * (base_cost / 100.0)
    nii_t0 = nii_t0_asset - nii_t0_liab
    
    res = {}
    for s_idx, sc_name in enumerate(S_names):
        p = nii_paths[s_idx, :]
        res[sc_name] = [nii_t0] + p.tolist() if include_t0 else p.tolist()
    return res
def optimize_portfolio_vectorized(df, tgt_budget, base_cost, depo_beta, S_names, YS_tensor, short_YS, obj_mode="Min-Max"):
    elig_i = np.where(df['Swap_Eligible'].values == 1)[0]
    if len(elig_i) == 0: return np.zeros(len(df))
    
    def obj_func(w_opt):
        W = np.zeros(len(df)); W[elig_i] = w_opt
        paths = calc_nii_paths_vectorized(W, df, S_names, YS_tensor, base_cost, depo_beta, short_YS, False)
        tots = [sum(p) for p in paths.values()]
        if "Min-Max" in obj_mode: return -np.percentile(tots, 5) if len(S_names) > 10 else -min(tots)
        else: return -np.mean(tots) if len(S_names) > 10 else -sum(SCENARIO_PROBS.get(s, 1.0/len(S_names)) * sum(paths[s]) for s in S_names)
    
    def c_max(w_opt):
        W = np.zeros(len(df)); W[elig_i] = w_opt
        return tgt_budget - np.sum(W * df['Realized_Loss'].values)
        
    bounds = tuple((0.0, 1.0) for _ in range(len(elig_i)))
    res = minimize(obj_func, np.zeros(len(elig_i)), method='SLSQP', bounds=bounds, constraints={'type': 'ineq', 'fun': c_max})
    final_W = np.zeros(len(df)); final_W[elig_i] = res.x
    return final_W * df['Book_Value'].values
def get_strategy_volumes(df, df_strategies, strategy_name, budget_limit=50.0):
    vols = np.zeros(len(df))
    if strategy_name == "現状維持 (すべて0)": return vols
    
    if strategy_name in DYNAMIC_STRATS:
        elig_df = df[df['Swap_Eligible'] == 1].copy()
        if elig_df.empty: return vols
        if strategy_name == "全銘柄を一律割合で入替 (予算上限)":
            tl = elig_df['Realized_Loss'].sum()
            if tl <= 0: return vols
            ratio = min(1.0, budget_limit / tl)
            for idx in elig_df.index: vols[idx] = df.at[idx, 'Book_Value'] * ratio
        else:
            sorted_df = elig_df.sort_values(by='Duration', ascending=(strategy_name == "短期から優先して入替 (予算上限)"))
            rb = budget_limit
            for idx in sorted_df.index:
                ml = sorted_df.at[idx, 'Realized_Loss']
                bv = sorted_df.at[idx, 'Book_Value']
                if ml <= 0:
                    vols[idx] = bv
                elif rb >= ml:
                    vols[idx] = bv
                    rb -= ml
                else:
                    vols[idx] = bv * (rb / ml)
                    break
        return vols
    
    for b_name in df['Bucket'].unique():
        match = df_strategies[(df_strategies['Strategy_Name'] == strategy_name) & (df_strategies['Bucket'] == b_name)]
        if not match.empty:
            vol = float(match['Swap_Volume'].values[0])
            b_items = df[(df['Bucket'] == b_name) & (df['Swap_Eligible'] == 1)]
            if not b_items.empty and b_items['Book_Value'].sum() > 0:
                ratio = min(1.0, vol / b_items['Book_Value'].sum())
                for idx in b_items.index: vols[idx] = ratio * b_items.at[idx, 'Book_Value']
    return vols
