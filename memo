def find_3d_best(merged_3d, cats):
    ret=merged_3d['期待リターン'].values; vol=merged_3d['ボラティリティ'].values; dd=merged_3d['max_dd'].values
    eps=1e-10
    rn=(ret-ret.min())/(ret.max()-ret.min()+eps)
    vn=1-(vol-vol.min())/(vol.max()-vol.min()+eps)
    dn=1-(dd-dd.min())/(dd.max()-dd.min()+eps)
    return merged_3d.iloc[(rn+vn+dn).argmax()]
def _norms_for_row(row, ev, metrics):
    """指定行のスコアをev全体に対して正規化"""
    return {m: (row[m]-ev[m].min())/(ev[m].max()-ev[m].min()) if ev[m].max()>ev[m].min() else 0.5 for m in metrics}
