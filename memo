            'Bucket': BUCKET_ORDER * 2,
            'Weight_Pct': [40, 40, 20, 0, 0] + [0, 0, 30, 40, 30]
        }).to_excel(writer, sheet_name='Reinvest_Policies', index=False)
        
        scens = []
        for sc in SCENARIO_PROBS.keys():
            for d, b_name in zip([2.0, 4.0, 6.0, 8.5, 12.0], BUCKET_ORDER):
                scens.append({'Scenario_Name': sc, 'Bucket': b_name, 'Year1_Shift': get_unified_ys(sc, 0, b_name, d), 'Year2_Shift': get_unified_ys(sc, 1, b_name, d), 'Year3_Shift': get_unified_ys(sc, 2, b_name, d), 'Year4_Shift': get_unified_ys(sc, 3, b_name, d), 'Year5_Shift': get_unified_ys(sc, 4, b_name, d)})
        pd.DataFrame(scens).to_excel(writer, sheet_name='Scenarios', index=False)
    return output.getvalue()
def optimize_portfolio(objective_func, df, budget):
    cons = {'type': 'ineq', 'fun': lambda w: budget - np.sum(w * df['Realized_Loss'])}
    bounds = tuple((0.0, 1.0) for _ in range(len(df)))
    res = minimize(objective_func, np.zeros(len(df)), method='SLSQP', bounds=bounds, constraints=cons)
    return res.x
