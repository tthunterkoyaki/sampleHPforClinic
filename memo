def gen_patterns(n,step=10):
    sc=100//step; res=[]
    def rec(i,rem,cur):
        if i==n-1: cur.append(rem*step); res.append(list(cur)); cur.pop(); return
        for k in range(rem+1): cur.append(k*step); rec(i+1,rem-k,cur); cur.pop()
    if n>0 and step>0: rec(0,sc,[])
    return np.array(res,dtype=float) if res else np.zeros((0,n))
def filter_bounds(pats,bmin,bmax):
    m=np.ones(len(pats),dtype=bool)
    for i in range(pats.shape[1]): m&=(pats[:,i]>=bmin[i])&(pats[:,i]<=bmax[i])
    return pats[m]
def eval_allocs(pats,alt_df,corr,trad_vol,illiq_w):
    if len(pats)==0: return pd.DataFrame()
    r=alt_df['期待リターン'].values; v=alt_df['ボラティリティ'].values; inc=alt_df['インカム利回り'].values
    rwa=alt_df['RWAウェイト'].values; lq=alt_df['流動性スコア'].values; tc=alt_df['対伝統資産相関'].values
    n=corr.shape[0]; W=pats/100.0
    er=W@r; cov_=np.outer(v,v)*corr[:n,:n]; pvar=np.einsum('ij,jk,ik->i',W,cov_,W)
    pvol=np.sqrt(np.maximum(pvar,0)); sr=np.divide(er,pvol,out=np.zeros_like(er),where=pvol>0)
    ic=W@inc; rw=W@rwa; ls=W@lq
    tw=1-illiq_w; cta=(W*tc[None,:]*v[None,:]).sum(1)
    rho=np.divide(cta,pvol,out=np.zeros_like(pvol),where=pvol>0); rho=np.clip(rho,-1,1)
    tv2=tw**2*trad_vol**2+illiq_w**2*pvol**2+2*tw*illiq_w*rho*trad_vol*pvol
    tvol=np.sqrt(np.maximum(tv2,0)); div=trad_vol-tvol
    ce=np.divide(er,rw,out=np.zeros_like(er),where=rw>0)
    cats=alt_df['カテゴリ'].tolist(); df=pd.DataFrame()
    for i,c in enumerate(cats): df[c]=pats[:,i]
    df['期待リターン']=er; df['ボラティリティ']=pvol; df['シャープレシオ']=sr; df['インカム利回り']=ic
    df['RWAウェイト']=rw; df['流動性スコア']=ls; df['分散効果']=div; df['資本効率']=ce; df['全体Vol']=tvol
    return df
def score_allocs(ev,weights):
    sc=pd.DataFrame(index=ev.index)
    for m in weights:
        if m not in ev.columns: continue
        col=ev[m]; mn,mx=col.min(),col.max()
        sc[m]=(col-mn)/(mx-mn) if mx>mn else 0.5
    return sum(sc[m]*w for m,w in weights.items() if m in sc.columns), sc
def norm_w(pw): s=sum(pw.values()); return {k:v/s for k,v in pw.items()} if s>0 else {k:1/len(pw) for k in pw}
